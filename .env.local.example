# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — your real keys never leave your machine.

# Helius RPC — free tier at https://www.helius.dev/
# Without this, the app falls back to https://api.devnet.solana.com (slower, rate-limited).
NEXT_PUBLIC_HELIUS_API_KEY=
NEXT_PUBLIC_HELIUS_DEVNET_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Default cluster the frontend connects to. Stays on devnet for the hackathon.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
