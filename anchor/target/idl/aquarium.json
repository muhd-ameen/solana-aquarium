        89,
        209,
        205,
        125,
        11
      ],
      "accounts": [
        {
          "name": "owner",
          "writable": true,
          "signer": true,
          "relations": [
            "parent_a",
            "parent_b"
          ]
        },
        {
          "name": "parent_a"
        },
        {
          "name": "parent_b"
        },
        {
          "name": "child",
          "writable": true
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": [
        {
          "name": "child_nonce",
          "type": "u8"
        }
      ]
    },
    {
